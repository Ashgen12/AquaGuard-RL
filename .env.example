# Server runtime
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Environment client/inference
ENV_SERVER_URL=http://localhost:8000

# LLM API (inference agent — plays the environment)
# NVIDIA NIM API — free, OpenAI-compatible
# Get your free API key at: https://build.nvidia.com
API_BASE_URL=https://integrate.api.nvidia.com/v1
MODEL_NAME=nvidia/nemotron-3-super-120b-a12b
OPENAI_API_KEY=nvapi-YOUR_NVIDIA_API_KEY
HF_TOKEN=hf_YOUR_HF_TOKEN

# LLM grader configuration (evaluates agent justification quality)
# Uses the same model as the inference agent for grading justifications
LLM_GRADER_PROVIDER=nvidia
LLM_GRADER_MODEL=nvidia/nemotron-3-super-120b-a12b
LLM_GRADER_API_KEY=nvapi-YOUR_NVIDIA_API_KEY

# Demo agent model (for run_sample_agent.py — best justification quality)
DEMO_MODEL_NAME=qwen/qwen3.5-397b-a17b